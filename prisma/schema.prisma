generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  image           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accounts        Account[]
  sessions        Session[]
  series          Series[]
  readingProgress ReadingProgress[]
  driveTokens     DriveToken[]
  settings        UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DriveToken {
  id           String   @id @default(cuid())
  userId       String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model Series {
  id              String            @id @default(cuid())
  userId          String
  title           String
  slug            String
  description     String?           @db.Text
  coverImage      String?
  coverDriveId    String?
  genres          String[]
  author          String?
  status          SeriesStatus      @default(ONGOING)
  totalVolumes    Int               @default(0)
  source          SourceType        @default(DRIVE)
  driveFolderId   String?
  anilistId       Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  volumes         Volume[]
  readingProgress ReadingProgress[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([slug])
}

model Volume {
  id              String            @id @default(cuid())
  seriesId        String
  title           String
  number          Int
  driveFileId     String?
  driveFolderId   String?
  fileType        FileType          @default(PDF)
  totalPages      Int?
  coverImage      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  series          Series            @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  readingProgress ReadingProgress[]

  @@unique([seriesId, number])
  @@index([seriesId])
}

model ReadingProgress {
  id          String   @id @default(cuid())
  userId      String
  seriesId    String
  volumeId    String
  currentPage Int      @default(1)
  totalPages  Int?
  completed   Boolean  @default(false)
  lastReadAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  volume      Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)

  @@unique([userId, volumeId])
  @@index([userId])
  @@index([seriesId])
}

model UserSettings {
  id               String           @id @default(cuid())
  userId           String           @unique
  readingDirection ReadingDirection @default(RTL)
  readingMode      ReadingMode      @default(PAGED)
  pageLayout       PageLayout       @default(SINGLE)
  backgroundColor  String           @default("#0f0f0f")
  autoScanDrive    Boolean          @default(false)
  lastDriveScan    DateTime?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SeriesStatus {
  ONGOING
  COMPLETED
  HIATUS
  CANCELLED
}

enum SourceType {
  DRIVE
  LOCAL
}

enum FileType {
  PDF
  IMAGE_FOLDER
  CBZ
  CBR
}

enum ReadingDirection {
  LTR
  RTL
}

enum ReadingMode {
  PAGED
  VERTICAL
}

enum PageLayout {
  SINGLE
  DOUBLE
}
